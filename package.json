{
  "name": "shynkro",
  "description": "Real-time collaborative workspace synchronization",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/atsika/shynkro.git"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "bun run --cwd packages/server dev",
    "build": "bun run --cwd packages/shared build && bun run --cwd packages/server build"
  },
  "dependencies": {
    "@types/bun": "^1.3.11",
    "yjs": "^13.6.0"
  }
}
